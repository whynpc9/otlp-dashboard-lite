{
  "name": "local-otel-workbench",
  "private": false,
  "version": "0.1.0",
  "description": "Local OTel Workbench CLI for microservices and AI agents.",
  "license": "MIT",
  "keywords": [
    "opentelemetry",
    "otlp",
    "dashboard",
    "tracing",
    "logs",
    "metrics",
    "genai",
    "mcp"
  ],
  "homepage": "https://github.com/whynpc9/local-otel-workbench#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whynpc9/local-otel-workbench.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/whynpc9/local-otel-workbench/issues"
  },
  "type": "module",
  "bin": {
    "otel-workbench": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "web-dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && node ../../scripts/build-cli.mjs",
    "package:web": "node ../../scripts/copy-web-dist.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "@grpc/grpc-js": "^1.14.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^3.1.4"
  }
}
