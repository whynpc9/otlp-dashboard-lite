{
  "name": "local-otel-workbench",
  "private": true,
  "version": "0.1.0",
  "description": "Local OTel Workbench CLI for microservices and AI agents.",
  "type": "module",
  "bin": {
    "otel-workbench": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@local-otel/server": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.1.4"
  }
}
